@model FootballStatistics.Web.ViewModels.ViewModels.Player.PlayerIndexViewModel

@using FootballStatistics.Common
@using Microsoft.AspNetCore.Mvc.Rendering


@{
    ViewData["Title"] = "Players";
}

<h2 class="text-center">@ViewData["Title"]</h2>
<hr />

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text"
                   name="searchTerm"
                   value="@Model.SearchTerm"
                   class="form-control"
                   placeholder="Search by player name..." />
        </div>

        <div class="col-md-3">
            <select name="position" class="form-select">
                <option value="">-- All positions --</option>
                @foreach (var position in Enum.GetValues(typeof(PlayerPosition)).Cast<PlayerPosition>())
                {
                    if (Model.Position.HasValue && Model.Position.Value == position)
                    {
                        <option value="@position" selected>@position</option>
                    }
                    else
                    {
                        <option value="@position">@position</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-3">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </div>
</form>

@if (User.IsInRole("Administrator"))
{
    <a asp-action="Create" class="btn btn-primary">Add Player</a>
}
<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Position</th>
            <th>Goals</th>
            <th>Team</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var player in Model.Players)
        {
            <tr>
                <td>@player.Name</td>
                <td>@player.Age</td>
                <td>@player.Position</td>
                <td>@player.GoalsScored</td>
                <td>@player.TeamName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@player.Id" class="btn btn-info btn-sm">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    @if (Model.CurrentPage > 1)
    {
        <a asp-action="Index"
           asp-route-searchTerm="@Model.SearchTerm"
           asp-route-position="@Model.Position"
           asp-route-page="@(Model.CurrentPage - 1)"
           class="btn btn-secondary">
            Previous
        </a>
    }

    <span class="mx-2">Page @Model.CurrentPage of @Model.TotalPages</span>

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a asp-action="Index"
           asp-route-searchTerm="@Model.SearchTerm"
           asp-route-position="@Model.Position"
           asp-route-page="@(Model.CurrentPage + 1)"
           class="btn btn-secondary">
            Next
        </a>
    }
</div>