

@using FootballStatistics.ViewModels.League
@model LeagueDetailsViewModel

@{
    ViewData["Title"] = "League Details";
}

<h2 class="text-center page-title">@ViewData["Title"]</h2>
<hr />

<div class="glass-card mb-3">
    <ul class="list-group custom-list-group mb-3">
        <li class="list-group-item"><strong>Name:</strong> @Model.Name</li>
        <li class="list-group-item"><strong>Country:</strong> @Model.Country</li>
    </ul>

    <h4 class="page-subtitle">Teams</h4>

    @if (!Model.Teams.Any())
    {
        <p class="details-text">No teams yet.</p>
    }
    else
    {
        <ul class="list-group custom-list-group">
            @foreach (var teamName in Model.Teams)
            {
                <li class="list-group-item">@teamName</li>
            }
        </ul>
    }

    <div class="mt-3 d-flex gap-2 flex-wrap">
        @if (User.IsInRole("Administrator"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
        }

        <a asp-action="Index" class="btn btn-secondary">Back</a>

        <a asp-controller="Leagues" asp-action="Standings" asp-route-id="@Model.Id" class="btn btn-primary">
            Standings
        </a>
    </div>
</div>