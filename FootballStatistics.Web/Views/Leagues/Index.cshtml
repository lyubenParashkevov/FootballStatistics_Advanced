@using FootballStatistics.ViewModels.League
@model IEnumerable<LeagueListItemModel>

@{
    ViewData["Title"] = "Leagues";
}

<h2 class="text-center">@ViewData["Title"]</h2>
<hr />

<div class="mb-3">
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">Add League</a>
    }
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Country</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var league in Model)
        {
            <tr>
                <td>@league.Name</td>
                <td>@league.Country</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@league.Id" class="btn btn-sm btn-info">
                        Details
                    </a>
                    
                </td>
            </tr>
        }
    </tbody>
</table>