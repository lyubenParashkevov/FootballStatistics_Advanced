@model FootballStatistics.Web.ViewModels.ViewModels.Match.MatchDetailsViewModel

@{
    ViewData["Title"] = "Match Details";
}

<h2 class="text-center">@ViewData["Title"]</h2>
<hr />

<ul class="list-group mb-3">

    <li class="list-group-item">
        <strong>Home Team:</strong> @Model.HomeTeamName
    </li>

    <li class="list-group-item">
        <strong>Away Team:</strong> @Model.AwayTeamName
    </li>

    <li class="list-group-item">
        <strong>Result:</strong> @Model.HomeGoals : @Model.AwayGoals
    </li>

    <li class="list-group-item">
        <strong>Date:</strong> @Model.MatchDate.ToString("dd MMM yyyy")
    </li>

    <li class="list-group-item">
        <strong>Stadium:</strong> @Model.Stadium
    </li>

</ul>

<div class="text-center">

    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">
            Edit
        </a>

        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger me-2">
            Delete
        </a>
    }

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>

</div>