@model FootballStatistics.Web.ViewModels.ViewModels.Player.PlayerDetailsViewModel

@{
    ViewData["Title"] = "Player Details";
}

<h2 class="text-center">@Model.Name</h2>
<hr />

<ul class="list-group">
    <li class="list-group-item"><strong>Age:</strong> @Model.Age</li>
    <li class="list-group-item"><strong>Position:</strong> @Model.Position</li>
    <li class="list-group-item"><strong>Goals:</strong> @Model.GoalsScored</li>
    <li class="list-group-item"><strong>Team:</strong> @Model.TeamName</li>
</ul>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>