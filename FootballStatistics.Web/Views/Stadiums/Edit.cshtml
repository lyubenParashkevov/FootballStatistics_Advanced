@model FootballStatistics.Web.ViewModels.ViewModels.Stadium.StadiumFormModel

@{
    ViewData["Title"] = "Edit Stadium";
}

<h2 class="text-center">@ViewData["Title"]</h2>
<hr />

<div class="row">
    <div class="col-md-6 offset-md-3">
        <form asp-action="Edit" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="City" class="form-label"></label>
                <input asp-for="City" class="form-control" />
                <span asp-validation-for="City" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Capacity" class="form-label"></label>
                <input asp-for="Capacity" class="form-control" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TeamId" class="form-label">Team</label>
                <select asp-for="TeamId" class="form-select">
                    <option value="">-- Select team --</option>
                    @foreach (var team in Model.Teams)
                    {
                        if (team.Id == Model.TeamId)
                        {
                            <option value="@team.Id" selected>@team.Name</option>
                        }
                        else
                        {
                            <option value="@team.Id">@team.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="TeamId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}