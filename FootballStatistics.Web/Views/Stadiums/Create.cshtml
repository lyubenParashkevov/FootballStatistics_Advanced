@model FootballStatistics.Web.ViewModels.ViewModels.Stadium.StadiumFormModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Create Stadium";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Create" method="post">
    <div class="form-group mb-2">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="City"></label>
        <input asp-for="City" class="form-control" />
        <span asp-validation-for="City" class="text-danger"></span>
    </div>

    <div class="form-group mb-2">
        <label asp-for="Capacity"></label>
        <input asp-for="Capacity" class="form-control" />
        <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="TeamId">Team</label>
        <select asp-for="TeamId"
                asp-items="@(new SelectList(Model.Teams, "Id", "Name"))"
                class="form-control">
        </select>
        <span asp-validation-for="TeamId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
<div asp-validation-summary="ModelOnly" class="text-center text-danger"></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}