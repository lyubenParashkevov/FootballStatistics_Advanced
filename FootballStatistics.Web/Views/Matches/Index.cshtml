@using FootballStatistics.ViewModels.Match
@model IEnumerable<MatchListItemModel>

@{
    ViewData["Title"] = "Matches";
}

<h2 class="text-center">@ViewData["Title"]</h2>
<hr />

<div class="mb-3">
    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Create" class="btn btn-primary">Add Match</a>
    }
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Home Team</th>
            <th class="text-center">Score</th>
            <th>Away Team</th>
            <th class="text-end">Actions</th>  
        </tr>
    </thead>
    <tbody>
        @foreach (var match in Model)
        {
            <tr>
                <td>@match.MatchDate.ToString("dd.MM.yyyy")</td>
                <td>@match.HomeTeamName</td>
                <td class="text-center">
                    @match.HomeGoals - @match.AwayGoals
                </td>
                <td>@match.AwayTeamName</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@match.Id" class="btn btn-sm btn-warning me-1">
                        Details                                                                                                     
                    </a>            
                </td>
            </tr>
        }
    </tbody>
</table>