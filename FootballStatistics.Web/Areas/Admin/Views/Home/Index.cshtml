@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="text-center">@ViewData["Title"]</h2>
<hr />

<div class="row g-3">
    <div class="col-md-4">
        <a asp-area="" asp-controller="Leagues" asp-action="Index" class="btn btn-primary w-100">
            Manage Leagues
        </a>
    </div>

    <div class="col-md-4">
        <a asp-area="" asp-controller="Teams" asp-action="Index" class="btn btn-primary w-100">
            Manage Teams
        </a>
    </div>

    <div class="col-md-4">
        <a asp-area="" asp-controller="Players" asp-action="Index" class="btn btn-primary w-100">
            Manage Players
        </a>
    </div>

    <div class="col-md-4">
        <a asp-area="" asp-controller="Stadiums" asp-action="Index" class="btn btn-primary w-100">
            Manage Stadiums
        </a>
    </div>

    <div class="col-md-4">
        <a asp-area="" asp-controller="Matches" asp-action="Index" class="btn btn-primary w-100">
            Manage Matches
        </a>
    </div>
</div>