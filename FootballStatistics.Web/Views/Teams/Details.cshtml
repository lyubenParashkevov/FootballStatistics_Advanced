@using FootballStatistics.ViewModels.Teams

@model TeamDetailsViewModel

@{
    ViewData["Title"] = "Team Details";
}

<h2 class="text-center">@ViewData["Title"]</h2>
<hr />

<ul class="list-group">
    <li class="list-group-item"><strong>Name:</strong> @Model.Name</li>
    <li class="list-group-item"><strong>League:</strong> @Model.LeagueName</li>
    <li class="list-group-item"><strong>Points:</strong> @Model.Points</li>
    <li class="list-group-item"><strong>Goals Scored:</strong> @Model.GoalsScored</li>
    <li class="list-group-item"><strong>Goals Conceded:</strong> @Model.GoalsConceded</li>
</ul>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>