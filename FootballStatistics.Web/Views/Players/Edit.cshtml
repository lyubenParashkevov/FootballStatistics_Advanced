@model FootballStatistics.Web.ViewModels.ViewModels.Player.PlayerFormModel

@{
    ViewData["Title"] = "Edit Player";
}

<h2 class="text-center">@ViewData["Title"]</h2>
<hr />

<div class="row">
    <div class="col-md-6 offset-md-3">
        <form asp-action="Edit" method="post">

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Age" class="form-label"></label>
                <input asp-for="Age" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Position" class="form-label"></label>
                <input asp-for="Position" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="GoalsScored" class="form-label"></label>
                <input asp-for="GoalsScored" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="TeamId" class="form-label">Team</label>
                <select asp-for="TeamId" class="form-select">
                    @foreach (var team in Model.Teams)
                    {
                        if (team.Id == Model.TeamId)
                        {
                            <option value="@team.Id" selected>@team.Name</option>
                        }
                        else
                        {
                            <option value="@team.Id">@team.Name</option>
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}